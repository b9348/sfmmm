{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-close",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-rename",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute"
  ]
}
